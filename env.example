# =============================================================================
# 必填项（缺一启动失败，参见 StartupConfig）
# =============================================================================

# ---- 数据库（必须） ----
DB_HOST=
DB_USER=
DB_PASSWORD=

# ---- AI（必须） ----
API_URL=https://api.deepseek.com/
MODEL_NAME=deepseek-v4-flash
API_KEY=

# ---- AI 删除卡片（S-1 安全重构，必填，否则启动 fail-fast） ----
# 接收删除验证码的邮箱（一般与 QQ_MAIL 相同）
CARD_NAV_DELETE_RECIPIENT=
# QQ 邮箱地址（如 123456@qq.com）
QQ_MAIL=
# QQ 邮箱 SMTP 授权码（不是登录密码！申请方式见 README）
QQ_AUTH_CODE=

# ---- Redis（必填，AI 删除验证码存储） ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Redis 密码（无密码可留空）
REDIS_PASSWORD=


# =============================================================================
# 可选项（有默认值，不填也行）
# =============================================================================

# 数据库连接
DB_PORT=3306
DB_NAME=card_nav

# 服务端口
SERVER_PORT=3002

# 旧版 AI 删除口令（S-1 改造后已废弃，但 yaml 里仍占位，避免 NullPointerException）
# ⚠️ 该字段已被 S-1 替代为 Redis + 邮件验证码机制；保留仅为兼容历史部署
CARD_NAV_SECURITY_DELETE_CONFIRMATION=

# AI 聊天限流（每 IP 每分钟）
AI_CHAT_RATE_LIMIT_PER_MINUTE=5

# QQ 邮件高级配置（一般不需修改）
# QQ_MAIL_HOST=smtp.qq.com
# QQ_MAIL_PORT=465